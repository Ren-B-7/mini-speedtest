# ── speedtest-cli Makefile ───────────────────────────────────────────────────
#
# Targets:
#   make              → build ./speedtest
#   make debug        → build with address-sanitiser + debug symbols
#   make clean        → remove build artefacts
#   make install      → install to /usr/local/bin (needs sudo)
#   make uninstall    → remove from /usr/local/bin

CC      := gcc
TARGET  := speedtest
SRCDIR  := src
INCDIR  := include
OBJDIR  := build

SRCS    := $(wildcard $(SRCDIR)/*.c)
OBJS    := $(patsubst $(SRCDIR)/%.c,$(OBJDIR)/%.o,$(SRCS))

# pkg-config resolves include/link flags portably
CFLAGS  := -Wall -Wextra -std=c11 -O2 \
           $(shell pkg-config --cflags libcurl libcjson) \
           -I$(INCDIR)
LDFLAGS := $(shell pkg-config --libs   libcurl libcjson)

# ── default target ───────────────────────────────────────────────────────────
.PHONY: all
all: $(OBJDIR) $(TARGET)

$(OBJDIR):
	mkdir -p $(OBJDIR)

$(TARGET): $(OBJS)
	$(CC) $(OBJS) $(LDFLAGS) -o $@
	@echo "Built: ./$@"

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ── debug build ──────────────────────────────────────────────────────────────
.PHONY: debug
debug: CFLAGS += -g -fsanitize=address,undefined -O0
debug: LDFLAGS += -fsanitize=address,undefined
debug: clean all

# ── install / uninstall ──────────────────────────────────────────────────────
PREFIX ?= /usr/local

.PHONY: install
install: all
	install -m 0755 $(TARGET) $(PREFIX)/bin/$(TARGET)
	@echo "Installed to $(PREFIX)/bin/$(TARGET)"

.PHONY: uninstall
uninstall:
	rm -f $(PREFIX)/bin/$(TARGET)

# ── clean ────────────────────────────────────────────────────────────────────
.PHONY: clean
clean:
	rm -rf $(OBJDIR) $(TARGET)
